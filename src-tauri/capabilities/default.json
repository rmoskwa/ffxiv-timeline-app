{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window: local file dialog + scoped FS access for timeline JSON files",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-app-write",
    "fs:allow-app-read",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appdata-read-recursive"
  ]
}
