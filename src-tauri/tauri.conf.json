{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FFXIV Timeline",
  "version": "0.3.0",
  "identifier": "app.ffxivtimeline",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/rmoskwa/ffxiv-timeline-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3NEEyMURFMTUxNjVFQkMKUldTOFhoWVYzaUZLdDVPREZ5NE9CY3BWNGl2cHhzRzlRTGdXcitVaCtJMWdzRTl1aUJ5bTVReGwK"
    }
  },
  "app": {
    "windows": [
      {
        "title": "FFXIV Timeline",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "publisher": "FFXIV Timeline",
    "copyright": "© 2026 rmoskwa",
    "category": "Utility",
    "shortDescription": "FFXIV raid timeline planner",
    "longDescription": "Local desktop app for building FFXIV raid timelines with boss abilities and per-player mitigation planning.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
